{
	"name": "magic-web",
	"version": "3.0.0",
	"private": true,
	"description": "Main Magic web application built with React and Vite for enterprise and open-source editions.",
	"keywords": [
		"react",
		"vite",
		"web-application",
		"enterprise",
		"typescript",
		"ai",
		"agent",
		"super-magic"
	],
	"homepage": "https://github.com/dtyq/magic/tree/master/frontend/magic-web#readme",
	"bugs": {
		"url": "https://github.com/dtyq/magic/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dtyq/magic.git",
		"directory": "frontend/magic-web"
	},
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"build": "pnpm build:opensource",
		"build:enterprise": "EDITION=enterprise node scripts/build.cjs",
		"build:iframe": "cd src/pages/superMagic/components/Detail/contents/HTML/iframe-runtime && pnpm run build",
		"build:opensource": "node scripts/build.cjs",
		"coverage": "vitest run --coverage",
		"dev": "pnpm dev:opensource",
		"dev:all": "concurrently --names \"opensource,enterprise\" --prefix-colors \"cyan,yellow\" \"PORT=4443 pnpm dev:opensource\" \"EDITION=enterprise node scripts/dev.cjs\"",
		"dev:enterprise": "EDITION=enterprise node scripts/dev.cjs",
		"dev:iframe": "cd src/pages/superMagic/components/Detail/contents/HTML/iframe-runtime && pnpm run build:watch",
		"dev:opensource": "node scripts/dev.cjs",
		"generate:icon-tags": "node scripts/icons/gen-tabler-icon-tags.cjs",
		"generate:theme-rgb-tokens": "pnpm tsx scripts/generate-theme-rgb-tokens.ts",
		"generate:theme-rgb-tokens:check": "pnpm tsx scripts/generate-theme-rgb-tokens.ts --check",
		"lh:audit": "pnpm tsx scripts/run-lh-audit.ts",
		"lh:install": "pnpm puppeteer browsers install chrome",
		"lh:view": "pnpm dlx lighthouse --output html --output-path lh-audit.html --input-path lh-audit.json",
		"lint": "eslint ./src --ext ts,tsx --format stylish --report-unused-disable-directives",
		"lint:fix": "eslint ./src --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
		"prepare": "husky",
		"preview": "vite preview",
		"test": "vitest run --config ./vitest.config.ts",
		"test:ci": "CI=true vitest run --config ./vitest.config.ts",
		"test:watch": "vitest run --config ./vitest.config.ts --watch",
		"typecheck": "tsc -p tsconfig.eslint.json",
		"wiki": "bash .cursor/skills/wiki-generator/scripts/serve-wiki.sh"
	},
	"lint-staged": {
		"./src/**/*.{js,jsx,ts,tsx}": [
			"eslint --fix --config .eslintrc.cjs",
			"prettier --write"
		],
		"./src/assets/locales/**/*.json": [
			"prettier --write"
		],
		"package.json": "sort-package-json"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
